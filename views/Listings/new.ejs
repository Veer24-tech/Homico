<% layout("layouts/boilerplate")%>
<body>
    <h2>Add you  apartment/vella</h2>
    <form  method="post" action="/listings">
       <label for="title">Title:</label>
        <input type="text" id="title" name="listing[title]" placeholder="Enter title of your listing">
        <br>
        <br>
        <br>
        <label for="description">Description:</label>
        <textarea id="description" name="listing[description]" placeholder="Enter description of your listing"></textarea>
        <br>
        <br>

        <label for="price">Price:</label>
        <input type="number" id="price" name="listing[price]" placeholder="Enter price of your listing">
        <br>
        <br>
        <label for="location">Location:</label>
        <input type="text" id="location" name="listing[location]" placeholder="Enter location of your listing">
        <br>
        <br>
        <label for="country">Country:</label>
        <input type="text" id="country" name="listing[country]" placeholder="Enter country of your listing">
        <br>
        <button type="submit">Save Listing</button>
    </form>
    
</body>
