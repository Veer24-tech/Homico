<% layout("layouts/boilerplate") %>

<div class="container mt-4">


    <div class="card show-card shadow">

        <img src="<%= listingDetails.image.url %>"
            class="card-img-top show-img"
            alt="listing-image">

        <div class="card-body">

            <h3 class="card-title">
                <%= listingDetails.title %>
            </h3>

            <p class="card-text">
                <%= listingDetails.description %>
            </p>

            <hr>

            <p>
                <strong>Price:</strong>
                ₹<%= listingDetails.price.toLocaleString('en-IN') %>
            </p>

            <p>
                <strong>Country:</strong>
                <%= listingDetails.country %>
            </p>

            <p>
                <strong>Location:</strong>
                <%= listingDetails.location %>
            </p>

            <div class="d-flex gap-3 mt-4">

                <a href="/listings/<%= listingDetails._id %>/edit"
                    class="btn btn-primary">
                    Edit
                </a>

                <form method="POST"
                    action="/listings/<%= listingDetails._id %>?_method=DELETE">

                    <button type="submit"
                        class="btn btn-danger ">
                        Delete
                    </button>

                </form>

            </div>

        </div>

    </div>
       <div class="mb-3 mt-3 offset-2">
    <h2>Drop your Review</h2>

    <form action="/listings/<%= listingDetails._id %>/reviews" method="POST">

        <div class="mb-3">
            <label for="rating">Ratings</label>
            <input
                type="range"
                class="form-range"
                id="rating"
                name="review[rating]"
                min="1"
                max="5">
        </div>

        <div class="mb-3">
            <label for="comment" class="form-label">
                Your experience with this property
            </label>

            <textarea name="review[comment]"
                id="comment"
                class="form-control"  
                 required></textarea>
                   <div class="valid-feedback">
        Please choose a username.
                   </div>
        </div>

        <button type="submit" class="btn btn-outline-dark">
            Done
        </button>

    </form>
</div>