<%layout("layouts/boilerplate")%>
<body>
    <h2>Listing details</h2>
    <ul>
        <li><%= listingDetails.title%></li>
        <li><%= listingDetails.description%></li>
        <li>&#8377;<%= listingDetails.price.toLocaleString('en-IN')%></li>  
         <!-- &#8377; used for rupee symbol   -->
    <!-- and .toLocaleString('en-IN') used for formatting the price in Indian format with commas  where (en-IN) is the locale for India -->
          <li><%= listingDetails.country%></li>
        <li><%= listingDetails.location%></li>
      
       
    </ul>
   <a href="/listings/<%=listingDetails.id%>/edit">Edit details</a>
 <form method="post" action="/listings/<%=listingDetails._id%>?_method=DELETE">
     <button type="submit">Delete Listing</button>
 </form>
</body>
</html>